---
import Logo from './Logo.astro';
import { NAV_ITEMS, SITE } from '../config/site.ts';
---

<header class="site">
  <div class="wrap nav">
    <Logo />
    <nav class="nav-menu" aria-label="グローバルナビゲーション">
      {NAV_ITEMS.map((item) => (
        <a class="link" href={item.href}>{item.label}</a>
      ))}
      <a class="btn btn-primary pressable nav-cta" href="/contact/">お問い合わせ</a>
    </nav>
    <button class="menu-btn" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-nav">
      <span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </button>
  </div>

  <!-- モバイル用ドロワー -->
  <nav id="mobile-nav" class="mobile-nav" aria-label="モバイルナビゲーション" hidden>
    {NAV_ITEMS.map((item) => (
      <a class="m-link" href={item.href}>{item.label}</a>
    ))}
    <a class="m-cta" href="/contact/">お問い合わせ</a>
    <a class="m-mail" href={`mailto:${SITE.email}`}>{SITE.email}</a>
  </nav>
</header>

<style>
  header.site {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255, 254, 250, .9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav { display: flex; align-items: center; justify-content: space-between; height: 72px; }
  .nav-menu { display: flex; align-items: center; gap: 26px; }
  .nav-menu a.link { font-size: 14px; font-weight: 500; color: var(--ink2); transition: color .15s; position: relative; }
  .nav-menu a.link:hover { color: var(--ink); }
  .nav-menu a.link:hover::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -6px;
    height: 3px; background: var(--yellow); border-radius: 2px;
  }
  .nav-cta { padding: 11px 22px; font-size: 13.5px; }

  .menu-btn {
    display: none; background: none; border: 0; cursor: pointer;
    width: 44px; height: 44px; flex-direction: column; justify-content: center; gap: 5px;
  }
  .menu-btn .bar { display: block; width: 24px; height: 2px; background: var(--ink); margin: 0 auto; transition: transform .2s, opacity .2s; }
  .menu-btn[aria-expanded="true"] .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-btn[aria-expanded="true"] .bar:nth-child(2) { opacity: 0; }
  .menu-btn[aria-expanded="true"] .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav {
    flex-direction: column; gap: 2px; padding: 8px 24px 20px;
    border-top: 1px solid var(--line); background: var(--paper);
  }
  .mobile-nav .m-link { padding: 14px 4px; font-size: 15px; font-weight: 700; border-bottom: 1px solid var(--line); }
  .mobile-nav .m-cta {
    margin-top: 14px; text-align: center; background: var(--yellow);
    border: 1.5px solid var(--ink); border-radius: 12px; padding: 14px; font-weight: 700;
    box-shadow: var(--shadow-press-sm);
  }
  .mobile-nav .m-mail { margin-top: 14px; text-align: center; font-family: var(--font-mono); font-size: 12px; color: var(--ink2); }

  @media (max-width: 680px) {
    .nav-menu { display: none; }
    .menu-btn { display: flex; }
    .mobile-nav:not([hidden]) { display: flex; }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.menu-btn');
  const drawer = document.getElementById('mobile-nav');
  if (btn && drawer) {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute('aria-label', open ? 'メニューを開く' : 'メニューを閉じる');
      drawer.hidden = open;
    });
  }
</script>
