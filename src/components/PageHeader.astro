---
/**
 * 下層ページ共通のページヘッダー（パンくず＋英字ラベル＋h1＋リード文）
 * パンくずの構造化データ(BreadcrumbList)は各ページ側で structured-data.ts の
 * breadcrumb() を BaseLayout の structuredData に渡す（表示とJSON-LDを一致させること）。
 */
interface Props {
  /** 英字ラベル（例: "SERVICE"） */
  eyebrow: string;
  /** ページ見出し */
  title: string;
  /** リード文（省略可） */
  lead?: string;
  /** パンくず。ホームは自動で先頭に付く */
  crumbs?: { name: string; path: string }[];
}
const { eyebrow, title, lead, crumbs = [] } = Astro.props;
---

<div class="page-head gridbg">
  <div class="wrap">
    <nav class="crumbs" aria-label="パンくずリスト">
      <ol>
        <li><a href="/">ホーム</a></li>
        {crumbs.map((c, i) => (
          <li aria-current={i === crumbs.length - 1 ? 'page' : undefined}>
            {i === crumbs.length - 1 ? c.name : <a href={c.path}>{c.name}</a>}
          </li>
        ))}
      </ol>
    </nav>
    <span class="eyebrow">{eyebrow}</span>
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
  </div>
</div>

<style>
  .page-head { border-bottom: 1px solid var(--line); }
  .page-head .wrap { padding: 40px 24px 64px; }
  .crumbs { font-size: 11.5px; color: var(--muted); margin-bottom: 40px; }
  .crumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: 6px; }
  .crumbs li + li::before { content: "›"; margin-right: 6px; color: var(--line); }
  .crumbs a { color: var(--ink2); }
  .crumbs a:hover { color: var(--ink); text-decoration: underline; text-decoration-color: var(--yellow); text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .22em; color: var(--amber-deep); }
  .eyebrow::before { content: ""; width: 26px; height: 2px; background: var(--ink); }
  h1 { margin-top: 14px; font-size: clamp(30px, 5vw, 44px); font-weight: 900; letter-spacing: .02em; line-height: 1.45; }
  .lead { margin-top: 18px; font-size: 14.5px; color: var(--ink2); line-height: 2.05; font-weight: 500; max-width: 640px; }
  @media (max-width: 680px) {
    .page-head .wrap { padding: 28px 24px 48px; }
    .crumbs { margin-bottom: 28px; }
  }
</style>
