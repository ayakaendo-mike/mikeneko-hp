---
/**
 * ブログ記事 個別ページ — microCMS（blog）連携。
 * 執筆者を明示（docs/03 4章 E-E-A-T対策）。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CtaSection from '../../components/CtaSection.astro';
import { breadcrumb, article } from '../../lib/structured-data.ts';
import { getList, type Blog } from '../../lib/microcms.ts';

export async function getStaticPaths() {
  const posts = await getList<Blog>('blog');
  return posts.map((p) => ({ params: { slug: p.slug ?? p.id }, props: { post: p } }));
}

interface Props { post: Blog; }
const { post } = Astro.props;

const crumbs = [
  { name: 'ブログ', path: '/blog/' },
  { name: post.title, path: `/blog/${post.slug ?? post.id}/` },
];
---

<BaseLayout
  title={post.title}
  description={post.metaDescription ?? post.title}
  ogType="article"
  structuredData={[breadcrumb(crumbs), article(post)]}
>
  <PageHeader eyebrow="BLOG" title={post.title} crumbs={crumbs} />

  <section class="detail">
    <div class="wrap">
      <div class="media">
        {post.eyecatch
          ? <img src={post.eyecatch.url} alt={post.title} />
          : <span class="ph">画像準備中</span>}
      </div>

      <div class="meta">
        {post.category && <span class="tag">{post.category}</span>}
        <time datetime={post.publishedAt}>{new Date(post.publishedAt).toLocaleDateString('ja-JP')}</time>
        <span class="author">執筆: {post.author}</span>
      </div>

      <div class="body" set:html={post.body} />

      {post.tags && post.tags.length > 0 && (
        <div class="tags">
          {post.tags.map((t) => <span class="tag-pill">#{t}</span>)}
        </div>
      )}
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  .detail { padding: 72px 0 120px; }
  .media { aspect-ratio: 16/9; background: var(--cream); border-radius: 16px; overflow: hidden; display: grid; place-items: center; margin-bottom: 32px; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .ph { font-family: var(--font-mono); font-size: 12px; letter-spacing: .2em; color: var(--amber-deep); }

  .meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 40px; }
  .meta .tag { display: inline-block; font-size: 10.5px; font-weight: 700; color: var(--ink2); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; letter-spacing: .03em; }
  .meta time { font-family: var(--font-mono); font-size: 11.5px; color: var(--muted); }
  .meta .author { font-size: 12.5px; color: var(--ink2); font-weight: 500; }

  .body { max-width: 720px; font-size: 14px; line-height: 2.05; color: var(--ink2); font-weight: 500; }
  .body :global(h2) { font-size: 18px; font-weight: 800; color: var(--ink); margin: 40px 0 16px; }
  .body :global(h3) { font-size: 15px; font-weight: 800; color: var(--ink); margin: 32px 0 12px; }
  .body :global(p) { margin: 0 0 16px; }
  .body :global(img) { width: 100%; border-radius: 12px; margin: 24px 0; }
  .body :global(a) { color: var(--amber-deep); text-decoration: underline; }

  .tags { margin-top: 40px; display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-pill { font-size: 11.5px; color: var(--amber-deep); font-family: var(--font-mono); }

  @media (max-width: 680px) { .detail { padding: 56px 0 96px; } }
</style>
