---
/**
 * よくある質問 — microCMS（faq）連携。
 * FAQPage構造化データはAIO対策の要（docs/03 3-5）。
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import { breadcrumb, faqPage } from '../lib/structured-data.ts';
import { getList, type Faq } from '../lib/microcms.ts';

const crumbs = [{ name: 'よくある質問', path: '/faq/' }];

const faqs = await getList<Faq>('faq', { orders: '-publishedAt' });
---

<BaseLayout
  title="よくある質問"
  description="みけねこデザインへよく寄せられる質問をまとめました。費用・相談の進め方・対応エリア・他社制作サイトの引き継ぎなど。ご相談・お見積りは無料です。"
  structuredData={[breadcrumb(crumbs), faqPage(faqs)]}
>
  <PageHeader
    eyebrow="FAQ"
    title="よくある質問"
    lead="ご相談の前によくいただく質問をまとめました。ここにない疑問は、お問い合わせフォームからお気軽にどうぞ。"
    crumbs={crumbs}
  />

  <section class="faq">
    <div class="wrap">
      <div class="qa-list">
        {faqs.map((f) => (
          <details class="qa">
            <summary><span class="q-mark" aria-hidden="true">Q</span>{f.question}</summary>
            <p><span class="a-mark" aria-hidden="true">A</span>{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaSection heading="ここにない疑問は、直接どうぞ。" />
</BaseLayout>

<style>
  .faq { padding: 72px 0 120px; }
  .qa-list { display: grid; gap: 12px; max-width: 760px; }
  .qa { background: #fff; border: 1px solid var(--line); border-radius: 12px; }
  .qa summary { cursor: pointer; padding: 18px 22px; font-size: 14.5px; font-weight: 700; display: flex; gap: 12px; align-items: baseline; list-style: none; }
  .qa summary::-webkit-details-marker { display: none; }
  .qa summary::after { content: "＋"; margin-left: auto; color: var(--amber-deep); font-weight: 700; }
  .qa[open] summary::after { content: "－"; }
  .qa .q-mark, .qa .a-mark { font-family: var(--font-en); font-weight: 800; color: var(--amber-deep); flex-shrink: 0; }
  .qa p { padding: 0 22px 20px 22px; font-size: 13.5px; line-height: 2.05; color: var(--ink2); font-weight: 500; display: flex; gap: 12px; align-items: baseline; }
  @media (max-width: 680px) { .faq { padding: 56px 0 96px; } }
</style>
