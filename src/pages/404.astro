---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" noindex={true}>
  <section class="nf">
    <div class="wrap">
      <p class="code">404</p>
      <h1>ページが見つかりません</h1>
      <p class="lead">お探しのページは移動または削除された可能性があります。<br />お手数ですが、トップページからお探しください。</p>
      <a class="btn btn-primary pressable" href="/">トップへ戻る<span class="ar">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding: 120px 0; text-align: center; }
  .nf .code { font-family: var(--font-en); font-size: clamp(64px, 14vw, 120px); font-weight: 800; color: var(--yellow); line-height: 1; }
  .nf h1 { font-size: clamp(22px, 4vw, 30px); font-weight: 900; margin-top: 8px; }
  .nf .lead { margin-top: 18px; font-size: 14px; color: var(--ink2); line-height: 2; }
  .nf .btn { margin-top: 32px; }
</style>
