---
import BaseLayout from '../layouts/BaseLayout.astro';
import CycleDiagram from '../components/CycleDiagram.astro';
import { localBusiness } from '../lib/structured-data.ts';

const services = [
  { no: 'S-01', ic: '▤', title: 'ホームページ制作', en: 'WEB PRODUCTION', desc: 'コーポレートサイト / LP / WordPress / Studio。目的に合わせて設計します。', href: '/service/homepage/' },
  { no: 'S-02', ic: '↻', title: 'Web改善・リニューアル', en: 'IMPROVEMENT', desc: 'サイトリニューアル / 保守・更新 / SEO改善 / 表示速度改善。', href: '/service/support/' },
  { no: 'S-03', ic: '✦', title: 'AI導入支援', en: 'AI SUPPORT', desc: '業務効率化・AI活用のご提案。お困りごとに合わせて伴走します。', href: '/service/ai/' },
  { no: 'S-04', ic: '✎', title: 'デザイン制作', en: 'GRAPHIC DESIGN', desc: '名刺 / チラシ / パンフレット / ロゴ / バナー。紙もお任せください。', href: '/service/graphic/' },
  { no: 'S-05', ic: '✆', title: 'LINE公式構築', en: 'LINE', desc: 'LINE公式アカウントの構築・運用で、集客とリピートの導線をつくります。', href: '/service/line/' },
  { no: 'S-06', ic: '⚙', title: 'ITサポート', en: 'IT SUPPORT', desc: 'PC・ツールの困りごと / クラウド導入 / 社内IT整備をサポート。', href: '/service/it-support/' },
];

const works = [
  { thumb: 'WEB SITE', cls: 't-web', cat: 'WEB', title: 'コーポレートサイト制作' },
  { thumb: 'GRAPHIC', cls: 't-graphic', cat: 'GRAPHIC', title: 'チラシ・記念誌デザイン' },
  { thumb: 'CARD', cls: 't-meishi', cat: 'MEISHI', title: '両面名刺デザイン' },
  { thumb: 'SUPPORT', cls: 't-support', cat: 'SUPPORT', title: 'IT・運用サポート' },
];

const features = [
  { num: '01', title: '伴走型サポート', body: '公開して終わりではなく、<b>「社外のWeb担当」</b>として運用まで並走。小さな更新のご相談も気軽にどうぞ。' },
  { num: '02', title: 'ワンストップ対応', body: 'Webも、名刺・チラシも、ITの困りごとも<b>窓口ひとつ</b>。デザインの一貫性も保てます。' },
  { num: '03', title: '数字にもとづく改善提案', body: 'アクセス解析をもとに、感覚ではなく<b>データで判断</b>。公開後も「次の一手」をご提案します。' },
  { num: '04', title: 'AIを味方にする制作', body: '最新のAIを制作・運用に活用し、<b>スピードと品質を両立</b>。業務効率化のご相談も歓迎です。' },
];

const steps = [
  { n: '1', st: 'ヒアリング', sd: '現状の課題とゴールを<br>お聞きします（無料）' },
  { n: '2', st: 'ご提案・お見積り', sd: '目的とご予算に合わせた<br>プランと概算をご提示' },
  { n: '3', st: '制作', sd: '進捗を共有しながら<br>丁寧に形にします' },
  { n: '4', st: '公開', sd: 'ドメイン・サーバーなど<br>公開作業までお任せ' },
  { n: '5', st: '運用・改善', sd: '公開後こそ本番。<br>育てる運用を継続サポート', hl: true },
];

// 画像・原稿は入稿待ち。image は実際の成果物画像パスが決まり次第セットする（未設定ならプレースホルダー表示）
const cases: { tags: string[]; title: string; image: string | null; rows: [string, string][] }[] = [
  {
    tags: ['建設業', 'コーポレートサイト'],
    title: '採用につながる会社の「顔」づくり',
    image: null,
    rows: [
      ['BEFORE', 'ホームページが無く、若手採用や新規の信頼獲得に苦戦'],
      ['支援', '映像を活かしたコーポレートサイトを新規制作'],
      ['AFTER', '<b>企業の勢いと想いが伝わる採用の入口</b>に'],
    ],
  },
  {
    tags: ['新規事業', 'ブランディング一式'],
    title: 'ゼロからの立ち上げをまるごと支援',
    image: null,
    rows: [
      ['BEFORE', '新規事業の立ち上げでロゴもWebも何も無い状態'],
      ['支援', 'ロゴ・名刺・Webサイトをトータルで制作'],
      ['AFTER', '<b>世界観が一貫したブランド</b>でスタートダッシュ'],
    ],
  },
  {
    tags: ['地域団体', '紙媒体・IT相談'],
    title: '「誰に頼めばいい？」をひとつの窓口に',
    image: null,
    rows: [
      ['BEFORE', 'チラシ・記念誌などの制作先がバラバラで負担大'],
      ['支援', 'デザイン制作からITの困りごとまで一括対応'],
      ['AFTER', '<b>相談先を一本化</b>して運営の手間を削減'],
    ],
  },
];
---

<BaseLayout isHome={true} structuredData={[localBusiness()]}>
  <!-- ============ HERO ============ -->
  <section class="hero gridbg">
    <div class="wrap">
      <div class="sun" aria-hidden="true"></div>
      <div class="orbit" aria-hidden="true">WEB &amp; IT</div>
      <div class="hero-inner">
        <span class="kicker">MIKENEKO DESIGN — WEB &amp; IT PARTNER</span>
        <h1>Webを、事業の<br /><span class="mk">「働く資産」</span>へ。</h1>
        <p class="lead">つくって終わりのホームページではなく、集客・採用・信頼につながるWebを。<br />中小企業の「Web担当」として伴走します。</p>
        <div class="actions">
          <a class="btn btn-primary pressable" href="/contact/">無料で相談してみる<span class="ar">→</span></a>
          <a class="btn pressable" href="#services">サービスを見る</a>
        </div>
        <div class="facts" role="list">
          <div class="fact" role="listitem"><span class="fl">STYLE</span><div class="fv">伴走型<br /><small>社外のWeb担当</small></div></div>
          <div class="fact" role="listitem"><span class="fl">SCOPE</span><div class="fv">ワンストップ<br /><small>Web・紙・IT・AI</small></div></div>
          <div class="fact" role="listitem"><span class="fl">AREA</span><div class="fv">千葉・東葛<br /><small>オンラインで全国対応</small></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 01 PROBLEM ============ -->
  <section class="problem">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>01</b> / PROBLEM</span>
          <h2 class="sec-title">こんなお悩み、<span class="hl">ありませんか？</span></h2>
        </div>
        <p class="sec-sub">Webのこと、ITのこと。「誰に相談すればいいか分からない」が、いちばん多いお悩みです。</p>
      </div>
      <div class="prob-grid">
        <div class="prob-card"><div class="qt">ホームページがまだ無い。名刺と紹介だけが頼りになっている</div><div class="qs">── 信頼の入口がWeb上にない状態です</div></div>
        <div class="prob-card"><div class="qt">発信したいのに、SNS頼みで情報が流れて消えていく</div><div class="qs">── ストックされない情報は、資産になりません</div></div>
        <div class="prob-card"><div class="qt">社内にWebやITに詳しい人がいない。相談相手がほしい</div><div class="qs">── 兼任担当者まかせでは限界があります</div></div>
        <div class="prob-card"><div class="qt">興味はあるけれど、何から始めればいいか正直わからない</div><div class="qs">── 実は、いちばん多いご相談です</div></div>
      </div>
      <div class="prob-band">
        <div class="big">その「最初の一歩」から、<br />みけねこデザインが伴走します。</div>
        <div class="small">まだ何も決まっていなくて大丈夫です。現状のお話を聞かせていただくところから、一緒に整理します。</div>
      </div>
    </div>
  </section>

  <!-- ============ 02 ABOUT ============ -->
  <section class="about" id="about">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>02</b> / ABOUT US</span>
          <h2 class="sec-title">「つくって、終わり」に<span class="hl">しない。</span></h2>
        </div>
      </div>
      <div class="about-grid">
        <div class="about-copy">
          <p>ホームページは、公開してからが本番です。更新・改善・運用を重ねることで、集客や採用、お問い合わせにつながる<b>「会社の資産」</b>に育っていきます。</p>
          <p>みけねこデザインは、Webサイトの制作にとどまらず、IT・AI・デザインまでまとめて相談できる<span class="mk">事業成長のパートナー</span>です。</p>
          <span class="chip">御社の「社外Web担当」であり、ITパートナーです</span>
        </div>
        <CycleDiagram />
      </div>
    </div>
  </section>

  <!-- ============ 03 SERVICES ============ -->
  <section class="services gridbg" id="services">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>03</b> / SERVICES</span>
          <h2 class="sec-title">サービス紹介</h2>
        </div>
        <p class="sec-sub">「つくる」から「育てる」まで。Webとデザインにまつわることを、まとめてご相談いただけます。</p>
      </div>
      <div class="svc-grid">
        {services.map((s) => (
          <a class="svc pressable" href={s.href}>
            <span class="no">{s.no}</span>
            <div class="ic" aria-hidden="true">{s.ic}</div>
            <h3>{s.title}<small>{s.en}</small></h3>
            <p>{s.desc}</p>
          </a>
        ))}
      </div>
      <div class="onestop">
        <span class="t">窓口は、<span class="y">ひとつ。</span></span>
        <span class="d">Webも、紙も、ITまわりも。「これは誰に頼めばいい？」と悩む時間をなくし、まとめてお引き受けします。</span>
      </div>
    </div>
  </section>

  <!-- ============ 04 WORKS ============ -->
  <section class="works" id="works">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>04</b> / WORKS</span>
          <h2 class="sec-title">制作実績</h2>
        </div>
        <p class="sec-sub">Webサイトから名刺・チラシまで。「手に取るデザイン」もお任せください。</p>
      </div>
      <div class="works-grid">
        {works.map((w) => (
          <a class="work-card pressable" href="/works/">
            <div class={`work-thumb ${w.cls}`}>{w.thumb}</div>
            <div class="work-body"><span class="cat">{w.cat}</span><div class="wt">{w.title}</div></div>
          </a>
        ))}
      </div>
      <div class="works-more"><a class="btn pressable" href="/works/">実績をもっと見る<span class="ar">→</span></a></div>
    </div>
  </section>

  <!-- ============ 05 FEATURES ============ -->
  <section class="features">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>05</b> / FEATURES</span>
          <h2 class="sec-title">みけねこデザインの<span class="hl">特徴</span></h2>
        </div>
        <p class="sec-sub">大手の「分業」でも、格安サービスの「作りっぱなし」でもない、ちょうどいい距離感で。</p>
      </div>
      <div class="feat-grid">
        {features.map((f) => (
          <div class="feat">
            <div class="num">{f.num}</div>
            <div>
              <h3>{f.title}</h3>
              <p set:html={f.body}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 06 FLOW ============ -->
  <section class="flow" id="flow">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>06</b> / FLOW</span>
          <h2 class="sec-title">ご相談の流れ</h2>
        </div>
        <p class="sec-sub">まずはお気軽にご相談ください。目的とご予算に合わせて、最適なプランをご提案します。</p>
      </div>
      <div class="flow-steps">
        <div class="rail" aria-hidden="true"></div>
        {steps.map((s) => (
          <div class:list={['step', { 'hl-step': s.hl }]}>
            <div class="dot">{s.n}</div>
            <div class="st">{s.st}</div>
            <div class="sd" set:html={s.sd}></div>
          </div>
        ))}
      </div>
      <div class="flow-note">
        <span class="m">ご相談・お見積りは無料です。</span>
        <span class="chip">オンライン対応OK</span>
        <span class="chip">相談だけでもOK</span>
      </div>
    </div>
  </section>

  <!-- ============ 07 CASE ============ -->
  <section class="cases gridbg">
    <div class="wrap">
      <div class="sec-head">
        <div>
          <span class="no"><b>07</b> / CASE</span>
          <h2 class="sec-title">過去の<span class="hl">事例</span></h2>
        </div>
        <p class="sec-sub">「何を相談して、何が変わったのか」。実際のご支援の流れをご紹介します。</p>
      </div>
      <div class="case-grid">
        {cases.map((c) => (
          <a class="case pressable" href="/works/">
            <div class="case-media">
              {c.image
                ? <img src={c.image} alt={c.title} loading="lazy" />
                : <span class="ph">画像準備中</span>}
            </div>
            <div class="case-body">
              <div class="tags">{c.tags.map((t) => <span class="tag">{t}</span>)}</div>
              <h3>{c.title}</h3>
              <dl>
                {c.rows.map(([dt, dd]) => (
                  <div><dt>{dt}</dt><dd set:html={dd}></dd></div>
                ))}
              </dl>
              <span class="more">詳しく見る →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="cases-note">※ 掲載内容は実際のご支援をもとにした一例です。詳しい実績は制作実績ページをご覧ください。</div>
      <div class="cases-more"><a class="btn pressable" href="/price/">料金の目安を見る<span class="ar">→</span></a></div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta" id="contact">
    <div class="wrap">
      <span class="k">CONTACT</span>
      <h2>まずは、「相談」から<br />始めませんか。</h2>
      <p class="lead">売り込みはいたしません。現状のお話を伺い、いま本当に必要なことを<br />一緒に整理するところから。</p>
      <div class="chips">
        <span class="chip">ご相談・お見積り 無料</span>
        <span class="chip">オンライン対応可</span>
        <span class="chip">その場で契約を迫りません</span>
      </div>
      <div class="actions">
        <a class="btn btn-primary pressable" href="/contact/">お問い合わせフォームへ<span class="ar">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ================= HERO ================= */
  .hero { overflow: hidden; border-bottom: 1px solid var(--line); }
  .hero .wrap { position: relative; padding: 96px 24px 110px; }
  .hero .sun {
    position: absolute; right: -80px; top: 60px; width: 420px; height: 420px; border-radius: 50%;
    background: radial-gradient(circle at 38% 34%, #FFE9B8 0%, var(--yellow) 55%, #F5A623 100%);
    z-index: 0;
  }
  .hero .sun::after { content: ""; position: absolute; inset: -34px; border-radius: 50%; border: 1.5px dashed rgba(35, 34, 44, .22); }
  .hero .orbit {
    position: absolute; right: 270px; top: 410px; width: 74px; height: 74px; border-radius: 50%;
    background: var(--white); border: 1.5px solid var(--ink); box-shadow: 0 4px 0 rgba(35, 34, 44, .9);
    display: flex; align-items: center; justify-content: center; font-family: var(--font-en);
    font-size: 10px; letter-spacing: .1em; font-weight: 700; z-index: 1;
  }
  .hero-inner { position: relative; z-index: 2; max-width: 660px; }
  .hero .kicker { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .2em; color: var(--ink2); margin-bottom: 24px; }
  .hero .kicker::before { content: ""; width: 26px; height: 2px; background: var(--ink); }
  .hero h1 { font-size: clamp(36px, 6.6vw, 64px); font-weight: 900; line-height: 1.38; letter-spacing: .01em; }
  .hero h1 .mk { background: linear-gradient(transparent 62%, var(--yellow) 62%); }
  .hero .lead { margin-top: 26px; font-size: clamp(15px, 2vw, 17px); color: var(--ink2); font-weight: 500; line-height: 2.1; }
  .hero .actions { margin-top: 38px; display: flex; flex-wrap: wrap; gap: 14px; }
  .hero .facts { margin-top: 52px; display: flex; gap: 0; border: 1.5px solid var(--ink); border-radius: 14px; overflow: hidden; background: #fff; max-width: 560px; box-shadow: var(--shadow-press); }
  .hero .fact { flex: 1; padding: 16px 18px; border-right: 1.5px solid var(--line); }
  .hero .fact:last-child { border-right: 0; }
  .hero .fact .fl { font-family: var(--font-mono); font-size: 9px; letter-spacing: .16em; color: var(--muted); }
  .hero .fact .fv { font-size: 14.5px; font-weight: 900; margin-top: 4px; line-height: 1.5; }
  .hero .fact .fv small { font-size: 10.5px; color: var(--ink2); font-weight: 700; }

  /* ================= PROBLEM ================= */
  .problem { padding: 112px 0 152px; }
  .prob-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 40px; }
  .prob-card { background: var(--cream); border-radius: 16px; padding: 26px 28px; }
  .prob-card .qt { font-size: 16px; font-weight: 700; line-height: 1.75; }
  .prob-card .qs { margin-top: 10px; font-size: 12.5px; color: var(--muted); }
  .prob-band {
    margin-top: 40px; background: linear-gradient(90deg, var(--yellow-soft), var(--yellow));
    border: 1.5px solid var(--ink); border-radius: 16px; padding: 32px 40px;
    display: flex; align-items: center; justify-content: space-between; gap: 26px;
    box-shadow: var(--shadow-press-lg);
  }
  .prob-band .big { font-size: clamp(19px, 2.6vw, 25px); font-weight: 900; line-height: 1.65; }
  .prob-band .small { font-size: 13px; line-height: 2; color: var(--ink2); font-weight: 500; min-width: 230px; max-width: 330px; }

  /* ================= ABOUT ================= */
  .about { padding: 112px 0 152px; background: var(--yellow-pale); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .about-grid { display: grid; grid-template-columns: 1fr 420px; gap: 60px; align-items: center; margin-top: 40px; }
  .about-copy p { font-size: 15px; line-height: 2.25; color: var(--ink2); margin-bottom: 18px; font-weight: 500; }
  .about-copy p b { color: var(--ink); }
  .about-copy p .mk { background: linear-gradient(transparent 66%, var(--yellow) 66%); color: var(--ink); font-weight: 700; }
  /* サイクル図のスタイルは components/CycleDiagram.astro 内に移動 */

  /* ================= SERVICES ================= */
  .services { padding: 112px 0 152px; }
  .svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 40px; }
  .svc { padding: 26px 26px; display: block; border-radius: 14px; }
  .svc .no { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; color: var(--muted); }
  .svc .ic { width: 44px; height: 44px; border-radius: 11px; background: var(--yellow-soft); display: flex; align-items: center; justify-content: center; margin: 14px 0; font-size: 19px; }
  .svc h3 { font-size: 16.5px; font-weight: 900; letter-spacing: .02em; }
  .svc h3 small { font-family: var(--font-en); display: block; font-size: 9px; letter-spacing: .22em; color: var(--muted); font-weight: 600; margin-top: 4px; }
  .svc p { margin-top: 10px; font-size: 12.5px; color: var(--ink2); line-height: 1.95; font-weight: 500; }
  .onestop { margin-top: 56px; border-radius: 14px; background: var(--cream); border: 1.5px solid var(--line); padding: 24px 32px; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .onestop .t { font-size: 16px; font-weight: 900; white-space: nowrap; }
  .onestop .t .y { background: linear-gradient(transparent 62%, var(--yellow) 62%); }
  .onestop .d { font-size: 13px; color: var(--ink2); line-height: 1.9; font-weight: 500; flex: 1; min-width: 260px; }

  /* ================= WORKS ================= */
  .works { padding: 112px 0 152px; background: var(--cream); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .works-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 40px; }
  .work-card { display: block; overflow: hidden; border-radius: 14px; }
  .work-thumb { aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; font-family: var(--font-en); font-size: 11px; letter-spacing: .16em; font-weight: 700; }
  .t-web { background: linear-gradient(135deg, var(--yellow), #F5A623); color: var(--ink); }
  .t-graphic { background: linear-gradient(135deg, #FFE9B8, var(--yellow)); color: var(--ink); }
  .t-meishi { background: linear-gradient(135deg, #F5A623, var(--amber)); color: #fff; }
  .t-support { background: linear-gradient(135deg, #FDF3DC, #FFE9B8); color: var(--ink2); }
  .work-body { padding: 14px 16px 18px; }
  .work-body .cat { font-family: var(--font-mono); font-size: 9.5px; font-weight: 500; color: var(--amber-deep); letter-spacing: .08em; }
