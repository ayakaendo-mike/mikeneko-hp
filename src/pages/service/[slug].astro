---
/**
 * サービス個別ページ（SEOピラーページ）
 * データは src/data/services.ts が唯一の出所。ページ追加はデータ追加のみで完結する。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CtaSection from '../../components/CtaSection.astro';
import { SERVICES, type Service } from '../../data/services.ts';
import { breadcrumb } from '../../lib/structured-data.ts';
import { SITE, SERVICE_AREAS } from '../../config/site.ts';

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

interface Props { service: Service; }
const { service } = Astro.props;

const crumbs = [
  { name: 'サービス', path: '/service/' },
  { name: service.title, path: `/service/${service.slug}/` },
];

// Service schema（docs/03 2章）
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  description: service.seoDescription,
  provider: { '@type': 'ProfessionalService', name: SITE.name, url: SITE.url },
  areaServed: SERVICE_AREAS.map((name) => ({ '@type': 'City', name })),
  url: new URL(`/service/${service.slug}/`, SITE.url).href,
};

const others = SERVICES.filter((s) => s.slug !== service.slug).slice(0, 3);
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  structuredData={[breadcrumb(crumbs), serviceSchema]}
>
  <PageHeader eyebrow={service.en} title={service.title} lead={service.lead} crumbs={crumbs} />

  <!-- こんな方に -->
  <section class="targets">
    <div class="wrap">
      <h2 class="h">こんな方に</h2>
      <ul class="t-list">
        {service.targets.map((t) => (
          <li><span class="check" aria-hidden="true">✓</span>{t}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 提供内容 -->
  <section class="offers gridbg">
    <div class="wrap">
      <h2 class="h">提供内容</h2>
      <div class="o-grid">
        {service.offers.map((o) => (
          <div class="o-card">
            <h3>{o.name}</h3>
            <p>{o.desc}</p>
          </div>
        ))}
      </div>
      <div class="point">
        <span class="pt">みけねこデザインの伴走ポイント</span>
        <p>{service.point}</p>
      </div>
      <div class="links">
        <a class="btn pressable" href="/price/">料金の目安を見る<span class="ar">→</span></a>
        <a class="btn pressable" href="/flow/">ご相談の流れを見る<span class="ar">→</span></a>
      </div>
    </div>
  </section>

  <!-- 他のサービス -->
  <section class="others">
    <div class="wrap">
      <h2 class="h">他のサービス</h2>
      <div class="os-grid">
        {others.map((s) => (
          <a class="os pressable" href={`/service/${s.slug}/`}>
            <span class="ic" aria-hidden="true">{s.icon}</span>
            <span class="tt">{s.title}</span>
            <span class="sm">{s.summary}</span>
          </a>
        ))}
      </div>
      <p class="all"><a href="/service/">サービス一覧へ →</a></p>
    </div>
  </section>

  <CtaSection heading={`${service.title}のご相談、お気軽にどうぞ。`} />
</BaseLayout>

<style>
  .h { font-size: clamp(20px, 3vw, 26px); font-weight: 900; letter-spacing: .02em; border-top: 2px solid var(--ink); padding-top: 32px; margin-bottom: 36px; }
  section { padding: 72px 0; }
  section:last-of-type { padding-bottom: 120px; }

  .t-list { list-style: none; display: grid; gap: 12px; max-width: 720px; }
  .t-list li { display: flex; gap: 12px; align-items: flex-start; background: var(--cream); border-radius: 12px; padding: 16px 20px; font-size: 14.5px; font-weight: 700; line-height: 1.8; }
  .t-list .check { color: var(--amber-deep); font-weight: 900; }

  .offers { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background-color: var(--paper); }
  .o-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .o-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 24px 24px; }
  .o-card h3 { font-size: 15.5px; font-weight: 900; letter-spacing: .02em; }
  .o-card p { margin-top: 10px; font-size: 12.5px; color: var(--ink2); line-height: 1.95; font-weight: 500; }
  .point { margin-top: 40px; background: linear-gradient(90deg, var(--yellow-soft), var(--yellow)); border: 1.5px solid var(--ink); border-radius: 16px; padding: 26px 32px; box-shadow: var(--shadow-press-lg); }
  .point .pt { display: block; font-family: var(--font-mono); font-size: 10px; letter-spacing: .18em; margin-bottom: 10px; }
  .point p { font-size: 14px; font-weight: 700; line-height: 2; }
  .links { margin-top: 40px; display: flex; gap: 14px; flex-wrap: wrap; }

  .os-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .os { display: block; padding: 20px 22px; border-radius: 14px; }
  .os .ic { display: inline-flex; width: 36px; height: 36px; border-radius: 9px; background: var(--yellow-soft); align-items: center; justify-content: center; font-size: 16px; margin-bottom: 10px; }
  .os .tt { display: block; font-size: 14.5px; font-weight: 900; }
  .os .sm { display: block; margin-top: 6px; font-size: 11.5px; color: var(--ink2); line-height: 1.8; font-weight: 500; }
  .all { margin-top: 26px; font-size: 13px; font-weight: 700; }
  .all a { color: var(--amber-deep); }

  @media (max-width: 900px) { .o-grid, .os-grid { grid-template-columns: 1fr; } }
  @media (max-width: 680px) { section { padding: 56px 0; } }
</style>
